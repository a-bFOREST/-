<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>نظام شرطة Forest</title>

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Tahoma,sans-serif;
}

body{
background:#0b0f17;
color:white;
padding:20px;
}

.section{
background:#141c29;
border:1px solid #00aaff33;
border-radius:15px;
padding:15px;
margin-bottom:20px;
box-shadow:0 0 15px #000;
}

.section h2{
color:#00aaff;
margin-bottom:15px;
font-size:28px;
}

.accordion{
background:#1b2435;
color:white;
cursor:pointer;
padding:15px;
width:100%;
border:none;
outline:none;
text-align:right;
font-size:18px;
margin-top:10px;
border-radius:10px;
transition:.3s;
}

.accordion:hover{
background:#24314b;
}

.panel{
display:none;
padding:15px;
background:#111827;
margin-top:5px;
border-radius:10px;
border-right:3px solid #00aaff;
}

.speed-box{
background:#111827;
padding:15px;
border-radius:10px;
line-height:2;
}

.admin{
margin-top:30px;
padding:20px;
border:2px dashed #2f3d57;
border-radius:20px;
background:#101827;
text-align:center;
}

.admin h2{
margin-bottom:20px;
color:#cfd8e3;
}

input{
width:90%;
max-width:350px;
padding:12px;
border:none;
border-radius:10px;
background:#000;
color:white;
font-size:18px;
margin-bottom:15px;
}

button.login{
padding:12px 25px;
border:none;
border-radius:10px;
background:#22314d;
color:white;
font-size:18px;
cursor:pointer;
}

.editable{
min-height:80px;
border:1px dashed #555;
padding:10px;
margin-top:10px;
border-radius:10px;
}

.saveBtn{
margin-top:10px;
padding:10px 20px;
background:#00aaff;
border:none;
border-radius:10px;
color:white;
cursor:pointer;
display:none;
}
</style>
</head>
<body>

<div class="section">
<h2>سياسات المركز والممنوعات</h2>

<button class="accordion">◀ السياسات</button>
<div class="panel editable" contenteditable="false" id="policy">
اكتب هنا...
</div>

<button class="accordion">◀ الممنوعات على المستجدين</button>
<div class="panel editable" contenteditable="false" id="newbies">
اكتب هنا...
</div>
</div>

<div class="section">
<h2>حدود السرعة</h2>

<div class="speed-box">
• مرآب الشرطة "طابق صفر" (25)<br>
• ڤينيس "VENICE" (لا يزيد عن 60)<br>
• كامبتون "CAMPTON" (بين 80-100)<br>
• في أماكن أخرى: (لا يزيد عن 100)<br>
• حد السرعة في المنطقة الخضراء: (40 ولا يتجاوز 60)
</div>
</div>

<div class="section">
<h2>سلسلة القيادة والرتب</h2>

<button class="accordion">◀ التسلسل الهرمي</button>
<div class="panel editable" contenteditable="false" id="hierarchy">
اكتب هنا...
</div>

<button class="accordion">◀ مهام كل رتب الفصيل</button>
<div class="panel editable" contenteditable="false" id="ranks">
اكتب هنا...
</div>
</div>

<div class="section">
<h2>نظام الترقيات</h2>

<button class="accordion">◀ ترقية من رتبة 0 إلى 1</button>
<div class="panel editable" contenteditable="false">اكتب هنا...</div>

<button class="accordion">◀ ترقية من رتبة 1 إلى 2</button>
<div class="panel editable" contenteditable="false">اكتب هنا...</div>

<button class="accordion">◀ ترقية من رتبة 2 إلى 3</button>
<div class="panel editable" contenteditable="false">اكتب هنا...</div>

<button class="accordion">◀ ترقية من رتبة 3 إلى 4</button>
<div class="panel editable" contenteditable="false">اكتب هنا...</div>

<button class="accordion">◀ ترقية من رتبة 4 إلى 5</button>
<div class="panel editable" contenteditable="false">اكتب هنا...</div>

<button class="accordion">◀ ترقية من رتبة 5 إلى 6</button>
<div class="panel editable" contenteditable="false">اكتب هنا...</div>

<button class="accordion">◀ ترقية من رتبة 6 إلى 7</button>
<div class="panel editable" contenteditable="false">اكتب هنا...</div>

<button class="accordion">◀ ترقية من رتبة 7 إلى 8</button>
<div class="panel editable" contenteditable="false">اكتب هنا...</div>

<button class="accordion">◀ ترقية من رتبة 8 إلى 9</button>
<div class="panel editable" contenteditable="false">اكتب هنا...</div>

</div>

<div class="section">
<h2>طريقة الاعتقال الصحيح</h2>

<button class="accordion">◀ اعتقال شخص مسلح أو غير مسلح</button>
<div class="panel editable" contenteditable="false">
اكتب هنا...
</div>

<button class="accordion">◀ طريقة استخدام التحذير الثالث (60 ثانية)</button>
<div class="panel editable" contenteditable="false">
اكتب هنا...
</div>
</div>

<div class="admin">
<h2>🔒 لوحة إدارة رئيس الفصيل (تعديل الأوامر)</h2>

<input type="password" id="pass" placeholder="أدخل كلمة المرور">

<br>

<button class="login" onclick="login()">
تفعيل وضع التعديل
</button>

<br>

<button class="saveBtn" id="saveBtn" onclick="saveData()">
حفظ التعديلات
</button>

</div>

<script>

let acc=document.getElementsByClassName("accordion");

for(let i=0;i<acc.length;i++){
acc[i].addEventListener("click",function(){
this.classList.toggle("active");

let panel=this.nextElementSibling;

if(panel.style.display==="block"){
panel.style.display="none";
}else{
panel.style.display="block";
}
});
}

function login(){

let password=document.getElementById("pass").value;

if(password==="1221"){

let items=document.querySelectorAll(".editable");

items.forEach(item=>{
item.contentEditable="true";
});

document.getElementById("saveBtn").style.display="inline-block";

alert("تم تفعيل وضع التعديل");

}else{
alert("كلمة المرور غير صحيحة");
}
}

function saveData(){

let items=document.querySelectorAll(".editable");

items.forEach((item,index)=>{
localStorage.setItem("content_"+index,item.innerHTML);
});

alert("تم حفظ التعديلات");
}

window.onload=function(){

let items=document.querySelectorAll(".editable");

items.forEach((item,index)=>{

let saved=localStorage.getItem("content_"+index);

if(saved){
item.innerHTML=saved;
}

});

}

</script>

</body>
</html>
